# Ignore everything
*

# Allow git and github
!.gitignore
!.github/
!.github/**

# Allow presentations
!ai-content-engine-v3.html
!ai-content-engine-v8-0311.html
!ai-content-engine-v12.html
!v8.html
!index.html
!积分兑换AI测MBTI_demo.html
!积分兑换AI写真demo.html
!积分兑换AI壁纸demo.html

# Allow client folders
!壹钱包×兑吧/
!壹钱包×兑吧/*.html
!平安银行信用卡/
!平安银行信用卡/*.html

# Allow compressed videos (for GitHub Pages)
!compressed/
!compressed/hook/
!compressed/hook/*.mp4
!compressed/idea/
!compressed/idea/*.mp4
!compressed/kos/
!compressed/kos/*.mp4
!compressed/drama/
!compressed/drama/*.mp4
!compressed/wall/
!compressed/wall/*.mp4

# Legacy compressed path
!视频案例/
!视频案例/compressed/
!视频案例/compressed/**/*.mp4
!视频案例/portrait/
!视频案例/portrait/*.png

# Exclude non-media junk
*.mov
*.DS_Store
